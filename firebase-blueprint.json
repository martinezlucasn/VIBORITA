{
  "entities": {
    "User": {
      "title": "User",
      "description": "Persistent user data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "coins": { "type": "number" },
        "monedas": { "type": "number" },
        "ownedSkins": { "type": "array", "items": { "type": "string" } },
        "equippedSkin": { "type": "string" },
        "highScore": { "type": "number" },
        "highScoreMonedas": { "type": "number" },
        "lastActive": { "type": "number" },
        "proAccessUntil": { "type": "number" },
        "millonarioAccessUntil": { "type": "number" }
      },
      "required": ["displayName", "coins"]
    },
    "TicketPurchase": {
      "title": "TicketPurchase",
      "description": "Log of arena access ticket purchases",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["pro", "millonario"] },
        "coinsPrice": { "type": "number" },
        "monedasPrice": { "type": "number" },
        "expiry": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "type", "coinsPrice", "monedasPrice", "expiry", "timestamp"]
    },
    "PlayerSession": {
      "title": "PlayerSession",
      "description": "Active player state in the arena",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "segments": { "type": "array", "items": { "type": "object", "properties": { "x": { "type": "number" }, "y": { "type": "number" } } } },
        "angle": { "type": "number" },
        "wager": { "type": "number" },
        "isAlive": { "type": "boolean" },
        "lastUpdate": { "type": "number" },
        "serverId": { "type": "string" },
        "color1": { "type": "string" },
        "color2": { "type": "string" },
        "skinEmoji": { "type": "string" },
        "isBoosting": { "type": "boolean" }
      },
      "required": ["userId", "segments", "angle", "wager", "isAlive", "lastUpdate", "serverId"]
    },
    "WagerPlayer": {
      "title": "WagerPlayer",
      "description": "Presence tracking for wager arena servers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serverId": { "type": "string" },
        "isAlive": { "type": "boolean" },
        "lastUpdate": { "type": "number" }
      },
      "required": ["id", "serverId", "isAlive", "lastUpdate"]
    },
    "Food": {
      "title": "Food",
      "description": "Food items in the arena",
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["normal", "gold", "speed", "star", "dropped"] },
        "color": { "type": "string" },
        "serverId": { "type": "string" }
      },
      "required": ["x", "y", "value", "type", "serverId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat messages in the arena",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "serverId": { "type": "string" }
      },
      "required": ["userId", "displayName", "text", "timestamp", "serverId"]
    },
    "KillEvent": {
      "title": "KillEvent",
      "description": "Events when a player kills another",
      "type": "object",
      "properties": {
        "killerName": { "type": "string" },
        "victimName": { "type": "string" },
        "timestamp": { "type": "number" },
        "serverId": { "type": "string" }
      },
      "required": ["killerName", "victimName", "timestamp", "serverId"]
    },
    "WagerCoin": {
      "title": "WagerCoin",
      "description": "Coins dropped in the wager arena",
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "value": { "type": "number" },
        "serverId": { "type": "string" },
        "expiresAt": { "type": "number" },
        "color": { "type": "string" }
      },
      "required": ["x", "y", "value", "serverId", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/arenaPlayers/{playerId}": {
      "schema": "PlayerSession",
      "description": "Active players in the arena"
    },
    "/wagerPlayers/{playerId}": {
      "schema": "WagerPlayer",
      "description": "Presence tracking for wager arena"
    },
    "/arenaFood/{foodId}": {
      "schema": "Food",
      "description": "Food items in the arena"
    },
    "/wagerCoins/{coinId}": {
      "schema": "WagerCoin",
      "description": "Dropped coins in the wager arena"
    },
    "/arenaChat/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chat messages in the arena"
    },
    "/arenaKills/{killId}": {
      "schema": "KillEvent",
      "description": "Kill events in the arena"
    },
    "/ticketPurchases/{purchaseId}": {
      "schema": "TicketPurchase",
      "description": "Log of ticket purchases"
    }
  }
}
