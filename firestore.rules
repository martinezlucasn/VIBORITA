// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - displayName: string (required)
//   - coins: number (required)
//   - ownedSkins: list of strings (optional)
//   - equippedSkin: string (optional)
//   - highScore: number (optional)
//   - lastActive: number (optional)
//
// Collection: arenaPlayers
// Document ID: {playerId}
// Fields:
//   - userId: string (required)
//   - displayName: string (required)
//   - segments: list of maps {x: number, y: number} (required)
//   - angle: number (required)
//   - wager: number (required)
//   - isAlive: boolean (required)
//   - lastUpdate: number (required)
//   - color1: string (optional)
//   - color2: string (optional)
//
// Collection: arenaFood
// Document ID: {foodId}
// Fields:
//   - x: number (required)
//   - y: number (required)
//   - value: number (required)
//   - type: string (required, ['normal', 'gold', 'speed', 'star', 'dropped'])
//   - color: string (optional)
//
// Collection: arenaChat
// Document ID: {chatId}
// Fields:
//   - userId: string (required)
//   - displayName: string (required)
//   - text: string (required)
//   - timestamp: number (required)
//
// Collection: arenaKills
// Document ID: {killId}
// Fields:
//   - killerName: string (required)
//   - victimName: string (required)
//   - timestamp: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          (request.auth.token.email == "martinezlucasn@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'email', 'displayName', 'amount', 'alias', 'status', 'timestamp']) &&
             data.userId is string &&
             data.email is string &&
             data.displayName is string &&
             data.amount is number &&
             data.amount >= 1000 &&
             data.alias is string &&
             data.status in ['pending', 'completed', 'rejected'] &&
             data.timestamp is number;
    }

    function isValidUser(data) {
      let requiredFields = ['displayName', 'coins', 'lastActive'];
      let optionalFields = ['id', 'email', 'ownedSkins', 'equippedSkin', 'highScore', 'highScoreMonedas', 'monedas', 'role', 'proAccessUntil', 'millonarioAccessUntil', 'usernameSet', 'botKills', 'insomniaCount', 'notifiedMedals', 'inventoryItems', 'inventoryAbilities', 'equippedAbilities', 'dailyRewardsCycle', 'lastDailyRewardClaim', 'lastActive', 'createdAt', 'updatedAt', 'lastLogin', 'bio', 'profileTheme', 'profileBorder', 'unlockedThemes', 'unlockedBorders', 'trophies', 'claimedPlatinumReward'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.displayName is string &&
             data.coins is number &&
             data.coins >= 0 &&
             data.lastActive is number &&
             (!('id' in data) || data.id is string) &&
             (!('email' in data) || data.email is string) &&
             (!('monedas' in data) || data.monedas is number) &&
             (!('highScore' in data) || data.highScore is number) &&
             (!('highScoreMonedas' in data) || data.highScoreMonedas is number) &&
             (!('equippedSkin' in data) || data.equippedSkin is string) &&
             (!('ownedSkins' in data) || data.ownedSkins is list) &&
             (!('role' in data) || data.role is string) &&
             (!('proAccessUntil' in data) || data.proAccessUntil is number) &&
             (!('millonarioAccessUntil' in data) || data.millonarioAccessUntil is number) &&
             (!('usernameSet' in data) || data.usernameSet is bool) &&
             (!('botKills' in data) || data.botKills is number) &&
             (!('insomniaCount' in data) || data.insomniaCount is number) &&
             (!('notifiedMedals' in data) || data.notifiedMedals is list) &&
             (!('inventoryItems' in data) || data.inventoryItems is map) &&
             (!('inventoryAbilities' in data) || data.inventoryAbilities is map) &&
             (!('equippedAbilities' in data) || data.equippedAbilities is list) &&
             (!('dailyRewardsCycle' in data) || data.dailyRewardsCycle is number) &&
             (!('lastDailyRewardClaim' in data) || data.lastDailyRewardClaim is number) &&
             (!('bio' in data) || data.bio is string) &&
             (!('profileTheme' in data) || data.profileTheme is string) &&
             (!('profileBorder' in data) || data.profileBorder is string) &&
             (!('unlockedThemes' in data) || data.unlockedThemes is list) &&
             (!('unlockedBorders' in data) || data.unlockedBorders is list) &&
             (!('trophies' in data) || data.trophies is number) && (!('claimedPlatinumReward' in data) || data.claimedPlatinumReward is bool);
    }

    function isValidTicketPurchase(data) {
      return data.keys().hasAll(['userId', 'type', 'coinsPrice', 'monedasPrice', 'expiry', 'timestamp']) &&
             data.userId is string &&
             data.type in ['pro', 'millonario'] &&
             data.coinsPrice is number &&
             data.monedasPrice is number &&
             data.expiry is number &&
             data.timestamp is number &&
             (!('email' in data) || data.email is string);
    }

    function isValidPlayer(data) {
      let requiredFields = ['userId', 'segments', 'angle', 'wager', 'isAlive', 'lastUpdate', 'serverId'];
      let optionalFields = ['id', 'displayName', 'spawnTime', 'color1', 'color2', 'skinEmoji', 'isBoosting'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.userId is string &&
             data.segments is list &&
             data.angle is number &&
             data.wager is number &&
             data.isAlive is bool &&
             data.lastUpdate is number &&
             data.serverId is string;
    }

    function isValidWagerPlayer(data) {
      let requiredFields = ['id', 'serverId', 'isAlive', 'lastUpdate'];
      return data.keys().hasAll(requiredFields) &&
             data.id is string &&
             data.serverId is string &&
             data.isAlive is bool &&
             data.lastUpdate is number;
    }

    function isValidFood(data) {
      return data.keys().hasAll(['x', 'y', 'value', 'type', 'serverId']) &&
             data.x is number &&
             data.y is number &&
             data.value is number &&
             data.type in ['normal', 'gold', 'speed', 'star', 'dropped'] &&
             data.serverId is string;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'displayName', 'text', 'timestamp', 'serverId']) &&
             data.userId is string &&
             data.displayName is string &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() < 200 &&
             data.timestamp is number &&
             data.serverId is string;
    }

    function isValidKill(data) {
      return data.keys().hasAll(['killerName', 'victimName', 'timestamp', 'serverId']) &&
             data.killerName is string &&
             data.victimName is string &&
             data.timestamp is number &&
             data.serverId is string;
    }

    function isValidPrivateRoom(data) {
      return data.keys().hasAll(['id', 'creatorId', 'wager', 'createdAt', 'status']) &&
             data.id is string &&
             data.creatorId is string &&
             data.wager is number &&
             data.wager >= 0 &&
             data.createdAt is number &&
             data.status in ['open', 'closed'];
    }

    function isValidSkinListing(data) {
      return data.keys().hasAll(['sellerId', 'sellerName', 'skinId', 'price', 'timestamp', 'status']) &&
             data.sellerId is string &&
             data.sellerName is string &&
             data.skinId is string &&
             data.price is number &&
             data.price > 0 &&
             data.timestamp is number &&
             data.status in ['active', 'sold'];
    }

    function isValidCompetitionStats(data) {
      return data is map;
    }

    function isValidFriendship(data) {
      return data.keys().hasAll(['uids', 'status', 'requesterId', 'gamesPlayed', 'timestamp']) &&
             data.uids is list &&
             data.uids.size() == 2 &&
             data.status in ['pending', 'accepted'] &&
             data.requesterId is string &&
             data.gamesPlayed is number &&
             data.timestamp is number &&
             (!('stats' in data) || data.stats is map) &&
             (!('lastMatch' in data) || data.lastMatch is number) &&
             (!('level' in data) || data.level is number) &&
             (!('exp' in data) || data.exp is number) &&
             (!('lastInteractionTime' in data) || data.lastInteractionTime is number);
    }

    function isValidPrivateMessage(data) {
      return data.keys().hasAll(['friendshipId', 'senderId', 'text', 'timestamp']) &&
             data.friendshipId is string &&
             data.senderId == request.auth.uid &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() <= 500 &&
             data.timestamp is number;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'fromId', 'fromName', 'toId', 'status', 'timestamp']) &&
             data.type in ['game_invite'] &&
             data.fromId is string &&
             data.fromName is string &&
             data.toId is string &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.timestamp is number &&
             (!('roomId' in data) || data.roomId is string) &&
             (!('wager' in data) || data.wager is number);
    }

    function isValidWebhookLog(data) {
      return data.keys().hasAll(['timestamp']) &&
             data.timestamp is timestamp;
    }

    function isValidProcessedPayment(data) {
      return data.keys().hasAll(['userId', 'amount', 'timestamp']) &&
             data.userId is string &&
             data.amount is number &&
             data.timestamp is timestamp;
    }

    function isValidArenaItem(data) {
      return data.keys().hasAll(['x', 'y', 'itemId', 'serverId']) &&
             data.x is number &&
             data.y is number &&
             data.itemId is string &&
             data.serverId is string;
    }

    function isValidAppConfig(data) {
      return data.keys().hasAll(['version', 'minVersion', 'downloadUrl']) &&
             data.version is string &&
             data.minVersion is string &&
             data.downloadUrl is string &&
             (!('updateMessage' in data) || data.updateMessage is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /arenaPlayers/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPlayer(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPlayer(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /arenaFood/{foodId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFood(request.resource.data);
      allow update: if isAuthenticated() && isValidFood(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /arenaItems/{itemId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidArenaItem(request.resource.data);
      allow update: if isAuthenticated() && isValidArenaItem(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /wagerCoins/{coinId} {
      allow get, list, create, update, delete: if isAuthenticated();
    }

    match /arenaChat/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'system');
      allow delete: if isAdmin();
    }

    match /arenaKills/{killId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidKill(request.resource.data);
      allow delete: if isAdmin();
    }

    match /wagerPlayers/{playerId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidWagerPlayer(request.resource.data) && (request.resource.data.id == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidWagerPlayer(request.resource.data) && (resource.data.id == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.id == request.auth.uid || isAdmin());
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /ticketPurchases/{purchaseId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTicketPurchase(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /privateRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPrivateRoom(request.resource.data) && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPrivateRoom(request.resource.data) && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated();
    }

    match /skinSales/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      isValidSkinListing(request.resource.data) && 
                      request.resource.data.sellerId == request.auth.uid &&
                      request.resource.data.status == 'active';
      allow update: if isAuthenticated() && (
        // Seller can update their own active listing (e.g., price change)
        (isOwner(resource.data.sellerId) && 
         isValidSkinListing(request.resource.data) && 
         resource.data.status == 'active' &&
         request.resource.data.sellerId == resource.data.sellerId) ||
        // Buyer can set status to 'sold'
        (resource.data.status == 'active' && 
         request.resource.data.status == 'sold' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid && resource.data.status == 'active');
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.uids);
      allow create: if isAuthenticated() && isValidFriendship(request.resource.data) && (request.auth.uid in request.resource.data.uids);
      allow update: if isAuthenticated() && isValidFriendship(request.resource.data) && (request.auth.uid in resource.data.uids);
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.uids);
    }

    match /privateMessages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/friendships/$(resource.data.friendshipId)).data.uids);
      allow create: if isAuthenticated() && 
                    isValidPrivateMessage(request.resource.data) && 
                    (request.auth.uid in get(/databases/$(database)/documents/friendships/$(request.resource.data.friendshipId)).data.uids);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
      allow create: if isAuthenticated() && isValidNotification(request.resource.data) && request.resource.data.fromId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
    }

    match /competitionStats/{statsId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /webhook_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /processed_payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    match /payment_notifications/{notificationId} {
      allow read, write: if isAdmin();
    }
  }
}
